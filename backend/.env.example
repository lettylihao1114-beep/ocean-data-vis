# ============================================
# 南海海洋数据可视化系统 — 环境变量配置模板
# ============================================
# 使用方法：
#   1. 复制此文件为 .env ：  cp .env.example .env
#   2. 填入真实的密钥值
#   3. 启动应用，dotenv 自动加载 .env 到系统属性
#
# 生产环境部署时，请使用系统环境变量代替 .env 文件。
# .env 仅用于本地开发，已被 .gitignore 排除，不会提交到 Git。
# ============================================

# 数据库配置（默认值适合本地开发，可留空）
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# JWT 签名密钥（生产环境务必更换为强随机字符串）
JWT_SECRET=your_jwt_secret_at_least_256_bits

# DeepSeek AI 对话 API Key（必需，无默认值）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# SiliconFlow 嵌入模型 API Key（必需，向量 RAG 检索用）
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
